body {
    margin: 0;
    font-family: Arial;
}

.header {
    background: #7b1b4d;
    color: white;
    text-align: center;
    padding: 20px;
}

.container {
    display: flex;
}

.left {
    width: 30%;
    padding: 20px;
}

.center {
    width: 40%;
    padding: 20px;
}

.right {
    width: 30%;
}

.right img {
    width: 100%;
}

.box {
    height: 200px;
    border: 2px solid black;
    display: flex;
    align-items: center;
    justify-content: center;
}

.tag {
    background: #123a5c;
    color: white;
    padding: 10px;
    margin-top: 20px;
}

input {
    width: 100%;
    padding: 8px;
    margin: 5px 0;
}

button {
    width: 100%;
    padding: 10px;
    background: red;
    color: white;
    border: none;
    margin-top: 10px;
}